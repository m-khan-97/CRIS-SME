# Environment variables for future Azure and reporting integration.
CRIS_SME_ENV=development
CRIS_SME_LOG_LEVEL=INFO
CRIS_SME_COLLECTOR=mock
CRIS_SME_DATA_DIR=data
CRIS_SME_OUTPUT_DIR=outputs/reports

# Azure collector settings
AZURE_SUBSCRIPTION_ID=
CRIS_SME_AZURE_ORGANIZATION_NAME=Azure SME Tenant
CRIS_SME_AZURE_SECTOR=SME
CRIS_SME_AZURE_TENANT_SCOPE=
CRIS_SME_AZURE_ORGANIZATION_ID=

# Optional plain-language narrator settings
CRIS_SME_ENABLE_NARRATOR=false
CRIS_SME_NARRATOR_PROVIDER=anthropic
CRIS_SME_NARRATOR_MODEL=claude-sonnet-4-20250514
CRIS_SME_NARRATOR_MAX_TOKENS=1400
CRIS_SME_NARRATOR_TEMPERATURE=0.2
CRIS_SME_NARRATOR_TIMEOUT_SECONDS=45
ANTHROPIC_API_KEY=
